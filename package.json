{
  "name": "minad-ui",
  "version": "0.0.1",
  "description": "一个基于Vue 3的移动端UI组件库",
  "keywords": [
    "vue",
    "ui",
    "mobile",
    "components"
  ],
  "author": "李红林 <1770679549@qq.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/minad-ui.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/minad-ui/issues"
  },
  "homepage": "https://github.com/your-username/minad-ui#readme",
  "main": "dist/minad-ui.umd.js",
  "module": "dist/minad-ui.es.js",
  "exports": {
    ".": {
      "import": "./dist/minad-ui.es.js",
      "require": "./dist/minad-ui.umd.js"
    },
    "./components/md-row/md-row": {
      "import": "./dist/components/md-row/md-row.vue",
      "require": "./dist/components/md-row/md-row.vue"
    },
    "./components/md-col/md-col": {
      "import": "./dist/components/md-col/md-col.vue",
      "require": "./dist/components/md-col/md-col.vue"
    },
    "./components/md-button/md-button": {
      "import": "./dist/components/md-button/md-button.vue",
      "require": "./dist/components/md-button/md-button.vue"
    },
    "./components/md-input/md-input": {
      "import": "./dist/components/md-input/md-input.vue",
      "require": "./dist/components/md-input/md-input.vue"
    },
    "./styles/*": "./dist/styles/*",
    "./utils/*": "./dist/utils/*"
  },
  "files": [
    "dist/**/*",
    "src/**/*",
    "README.md"
  ],
  "type": "module",
  "engines": {
    "node": "^14.18.0 || >=16.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint . --fix --cache",
    "lint": "run-s lint:*",
    "format": "prettier --write src/",
    "build:lib": "vite build --mode lib",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate": "plop",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "create-component": "node scripts/create-component.js"
  },
  "dependencies": {
    "@vue/shared": "^3.5.24",
    "vue": "^3.5.22"
  },
  "devDependencies": {
    "@prettier/plugin-oxc": "^0.0.4",
    "@tsconfig/node22": "^22.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.18.11",
    "@vitejs/plugin-vue": "^4.0.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.37.0",
    "eslint-plugin-oxlint": "~1.23.0",
    "eslint-plugin-vue": "~10.5.0",
    "fs-extra": "^11.3.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "jiti": "^2.6.1",
    "jsdom": "^27.2.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.23.0",
    "plop": "^4.0.4",
    "prettier": "3.6.2",
    "sass": "^1.83.0",
    "ts-jest": "^29.4.5",
    "typescript": "~5.9.0",
    "vite": "4.0.4",
    "vite-plugin-vue-devtools": "^8.0.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.13",
    "vue-jest": "^4.0.1",
    "vue-tsc": "^3.1.1"
  }
}
